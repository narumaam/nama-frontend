# ─────────────────────────────────────────────────────────────────────────────
# NAMA Travel Platform - Environment Configuration Template
# ─────────────────────────────────────────────────────────────────────────────
#
# Copy this file to .env and fill in the actual values for your environment:
#   cp .env.example .env
#
# For Docker Compose:
#   - Place .env file in the project root directory
#   - Docker Compose will automatically load these variables
#   - All variables are injected into service containers via docker-compose.yml
#
# For production deployment:
#   - Use secure secret management (e.g., HashiCorp Vault, AWS Secrets Manager)
#   - Never commit .env files to version control
#   - Rotate secrets regularly
#   - Use strong, randomly generated values for SECRET_KEY and REFRESH_SECRET_KEY

# ─────────────────────────────────────────────────────────────────────────────
# DATABASE CONFIGURATION
# ─────────────────────────────────────────────────────────────────────────────

# PostgreSQL connection string
# Format: postgresql://username:password@host:port/database
# For Docker Compose: use 'db' as hostname
# For local development: use 'localhost'
# For production: use your managed database endpoint
DATABASE_URL=postgresql://nama_user:nama_password@db:5432/nama_db

# Docker Compose - Individual PostgreSQL variables (alternative to DATABASE_URL)
DB_USER=nama_user
DB_PASSWORD=nama_password
DB_NAME=nama_db

# ─────────────────────────────────────────────────────────────────────────────
# REDIS CONFIGURATION
# ─────────────────────────────────────────────────────────────────────────────

# Redis connection string
# Format: redis://[:password]@host:port/database
# For Docker Compose: use 'redis' as hostname
# For local development: use 'localhost'
# For production: use your managed Redis endpoint
REDIS_URL=redis://redis:6379/0

# ─────────────────────────────────────────────────────────────────────────────
# APPLICATION SECURITY
# ─────────────────────────────────────────────────────────────────────────────

# Secret key for JWT token signing and data encryption
# IMPORTANT: Generate a strong random key for production
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars

# Secret key for refresh token signing
# IMPORTANT: Use a different key from SECRET_KEY
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
REFRESH_SECRET_KEY=your-refresh-secret-key-change-in-production-min-32-chars

# ─────────────────────────────────────────────────────────────────────────────
# LOGGING CONFIGURATION
# ─────────────────────────────────────────────────────────────────────────────

# Log level for application and Gunicorn
# Options: critical, error, warning, info, debug
# Production: info or warning
# Development: debug
LOG_LEVEL=info

# ─────────────────────────────────────────────────────────────────────────────
# API & SERVICE CONFIGURATION
# ─────────────────────────────────────────────────────────────────────────────

# AI service budget in USD (for Anthropic API calls)
# Controls maximum spend on AI features per billing cycle
AI_BUDGET_USD=100

# Frontend API URL for client-side requests
# Docker Compose: http://backend:8000 (internal)
# Local development: http://localhost:8000
# Production: https://api.yourdomain.com
NEXT_PUBLIC_API_URL=http://backend:8000

# ─────────────────────────────────────────────────────────────────────────────
# PAYMENT PROVIDER CONFIGURATION - Stripe
# ─────────────────────────────────────────────────────────────────────────────

# Stripe API secret key for backend operations
# Get from: https://dashboard.stripe.com/apikeys
# Format: sk_live_... (production) or sk_test_... (development)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key

# Stripe webhook signing secret for validating webhook payloads
# Get from: https://dashboard.stripe.com/webhooks
# Used to verify webhook authenticity
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret

# ─────────────────────────────────────────────────────────────────────────────
# PAYMENT PROVIDER CONFIGURATION - Razorpay
# ─────────────────────────────────────────────────────────────────────────────

# Razorpay API Key ID for payment operations
# Get from: https://dashboard.razorpay.com/#/app/keys
RAZORPAY_KEY_ID=rzp_live_your_razorpay_key_id

# Razorpay API Key Secret for payment operations
# Get from: https://dashboard.razorpay.com/#/app/keys
# Keep this secret and never expose it
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# ─────────────────────────────────────────────────────────────────────────────
# GUNICORN WORKER CONFIGURATION
# ─────────────────────────────────────────────────────────────────────────────

# Number of Gunicorn workers
# Formula: (2 × CPU cores) + 1
# For 4 CPU cores: 9 workers
# For 8 CPU cores: 17 workers
# Adjust based on your server capacity
WEB_CONCURRENCY=4

# ─────────────────────────────────────────────────────────────────────────────
# DEPLOYMENT NOTES
# ─────────────────────────────────────────────────────────────────────────────
#
# Docker Compose Local Development:
#   1. Copy: cp .env.example .env
#   2. Update values as needed
#   3. Run: docker-compose up -d
#   4. View logs: docker-compose logs -f
#
# Production Deployment (Railway, Heroku, etc.):
#   1. Use environment variables dashboard in your platform
#   2. Never commit .env to version control
#   3. Use strong, randomly generated secrets
#   4. Enable HTTPS/TLS for all connections
#   5. Use managed database and cache services
#   6. Set LOG_LEVEL=warning for production
#   7. Monitor and rotate secrets regularly
#
# Security Best Practices:
#   - Never hardcode secrets in configuration files
#   - Rotate secrets quarterly
#   - Use different keys for development and production
#   - Enable audit logging for production deployments
#   - Monitor API usage and rate limiting
#   - Use VPN/firewall to restrict database access
