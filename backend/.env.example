# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/nama

# ── Auth ──────────────────────────────────────────────────────────────────────
SECRET_KEY=your-secret-key-here
NAMA_JWT_SECRET=your-jwt-secret-here
NAMA_API_KEY=your-internal-api-key-here

# ── AI Providers ──────────────────────────────────────────────────────────────
# Anthropic Claude — required for agent calls and Copilot fallback
ANTHROPIC_API_KEY=sk-ant-...

# OpenRouter — preferred provider for Copilot (free Llama 3.3 70B)
OPENROUTER_API_KEY=sk-or-...

# ── Vercel AI Gateway (optional) ─────────────────────────────────────────────
# When set, all Anthropic calls are routed through the Vercel AI Gateway for
# observability, caching, and multi-model routing.
# Gateway URL format:
#   https://gateway.ai.vercel.com/v1/{VERCEL_AI_GATEWAY_TEAM_ID}/{VERCEL_AI_GATEWAY_NAME}/anthropic
#
# Leave unset for local dev (calls go directly to api.anthropic.com).
VERCEL_AI_GATEWAY_TEAM_ID=team_0ntK3Ywi8mYGSkVagPrRDXhd
VERCEL_AI_GATEWAY_NAME=nama-ai-gateway

# ── AI Kill-Switch ────────────────────────────────────────────────────────────
# Set to 1 to immediately disable ALL agent calls without a code deploy.
AI_KILL_SWITCH=0

# ── Redis / Rate Limiting ─────────────────────────────────────────────────────
UPSTASH_REDIS_REST_URL=https://...
UPSTASH_REDIS_REST_TOKEN=...

# ── Error Monitoring ──────────────────────────────────────────────────────────
SENTRY_DSN=https://...

# ── Email ─────────────────────────────────────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=no-reply@example.com
SMTP_PASSWORD=...

# ── Google OAuth ──────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=...
GOOGLE_CLIENT_SECRET=...
