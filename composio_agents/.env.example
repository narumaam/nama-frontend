# NAMA Travel OS — Composio Agents Environment Variables
# 1. Copy this file: cp .env.example .env
# 2. Fill in every value below
# 3. Never commit .env to git

# Core AI
GEMINI_API_KEY=AIza...your-gemini-api-key
COMPOSIO_API_KEY=your-composio-api-key

# Google Workspace
GOOGLE_SHEETS_DMC_REGISTRY_ID=1BxiM...your-dmc-registry-sheet-id
GOOGLE_SHEETS_LEADS_ID=1BxiM...your-leads-pipeline-sheet-id
GOOGLE_SHEETS_PNL_ID=1BxiM...your-pnl-ledger-sheet-id
GOOGLE_SHEETS_PRICING_ID=1BxiM...your-pricing-dashboard-sheet-id

# Notion
NOTION_DMC_DATABASE_ID=your-notion-database-id

# HubSpot
HUBSPOT_PORTAL_ID=your-hubspot-portal-id
HUBSPOT_DEFAULT_OWNER_ID=your-hubspot-owner-id

# Slack
SLACK_OPS_CHANNEL=#nama-ops

# NAMA Internal
NAMA_OPS_EMAIL=ops@namatravelos.com
PNL_DIGEST_RECIPIENT=owner@yourdmc.com
REVENUE_MANAGER_EMAIL=revenue@yourdmc.com

# NAMA Backend
NAMA_BACKEND_URL=https://stunning-joy-production-87bb.up.railway.app
NAMA_API_KEY=your-nama-internal-api-key
